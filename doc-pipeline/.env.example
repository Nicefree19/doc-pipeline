# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Google Sheets (service account JSON path)
GOOGLE_CREDENTIALS_PATH=config/service_account.json
SPREADSHEET_ID=your_google_spreadsheet_id_here

# NAS paths (watched folders)
NAS_ROOT=//NAS_SERVER/공유폴더
WATCH_CONTRACTS=//NAS_SERVER/공유폴더/계약서
WATCH_ACTION_PLANS=//NAS_SERVER/공유폴더/조치계획서
WATCH_OPINIONS=//NAS_SERVER/공유폴더/의견서

# ChromaDB
CHROMA_PERSIST_DIR=./data/chromadb
FTS_ENABLED=true
FTS_DB_PATH=./data/chunks_fts.db
FTS_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# Processing
OCR_ENGINE=marker
DEFAULT_SECURITY_GRADE=C
MAX_GEMINI_RPM=14

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Nova API Server (프로덕션 배포 시 'production'으로 변경)
NOVA_ENV=development
# CORS_ORIGINS — Cross-Origin Resource Sharing 허용 도메인 (쉼표 구분)
#   개발 모드: 설정 불필요 (localhost:5173,5174 자동 허용)
#   Docker 단일 서버: 설정 불필요 (nginx 리버스 프록시로 same-origin)
#   프론트/백 분리 배포: CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
#   다중 도메인: CORS_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
NOVA_PORT=80

# API Authentication
#   개발: 비워두면 인증 비활성화 (모든 요청 허용)
#   프로덕션: 반드시 강력한 키 설정 (NOVA_ENV=production 시 필수)
#   생성 예시: python -c "import secrets; print(secrets.token_urlsafe(32))"
NOVA_API_KEY=

# Rate Limiting (requests per minute)
RATE_LIMIT_PER_MIN=30
RATE_LIMIT_UPLOAD_PER_MIN=5
# Trusted Proxy — X-Forwarded-For 헤더를 신뢰할지 여부
#   Docker/nginx 뒤: TRUST_PROXY=true (docker-compose.yml에서 자동 설정됨)
#   직접 노출: TRUST_PROXY=false (기본값, 클라이언트 IP 위조 방지)
TRUST_PROXY=false

# OCR Gateway (Phase 1+)
OCR_GATEWAY_URL=http://localhost:8010
OCR_GATEWAY_TIMEOUT=120
OCR_FALLBACK_ENGINE=marker
OCR_QUALITY_THRESHOLD=0.6
OCR_GATEWAY_ENABLED=false

# Document Registry
REGISTRY_DB_PATH=./data/registry.db
MANAGED_STORAGE_DIR=./data/managed
REGISTRY_ENABLED=true

# Method Docs scanner (optional prod wrapper default)
METHOD_DOCS_SCAN_DIR=D:\00.Work_AI_Tool\15.Filename\00.공법자료

# PydanticAI Agent (feature toggle — 기본 비활성)
#   기존 Gemini LLM 직접 호출 대신 PydanticAI 에이전트(구조화 출력, 자동 재시도) 사용.
#   설치 필요: pip install doc-pipeline[agents]
AGENT_ENABLED=false
AGENT_MODEL=google-gla:gemini-2.0-flash
AGENT_TEMPERATURE=0.3
AGENT_MAX_RETRIES=2

# OpenTelemetry 관찰성 (optional)
#   에이전트 실행을 분산 추적 span으로 기록.
#   설치 필요: pip install doc-pipeline[observability]
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317
